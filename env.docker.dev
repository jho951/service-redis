COMPOSE_PROJECT_NAME=redis-server-dev
REDIS_PORT=6379
REDIS_BIND_HOST=127.0.0.1
REDIS_BIND_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_CONFIG_FILE=/usr/local/etc/redis/dev/redis.conf
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_IMAGE=central-redis:dev
REDIS_CONTAINER_NAME=central-redis-dev
REDIS_DATA_VOLUME=./data/dev
REDIS_LOG_VOLUME=./logs/dev
SHARED_SERVICE_NETWORK=backend-shared
REDIS_EXPORTER_BIND_HOST=127.0.0.1
REDIS_EXPORTER_PORT=9121
REDIS_EXPORTER_CONTAINER_NAME=central-redis-exporter-dev
