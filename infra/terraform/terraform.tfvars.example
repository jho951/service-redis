aws_region   = "ap-northeast-2"
project_name = "msa"
environment  = "prod"

service_name = "redis-server"

vpc_cidr             = "10.25.0.0/16"
private_subnet_cidrs = ["10.25.11.0/24", "10.25.12.0/24"]

# Allow only service VPCs, peered VPCs, or private network ranges that should use central Redis.
redis_client_cidrs = ["10.20.0.0/12"]

redis_engine_version       = "7.1"
redis_node_type            = "cache.t4g.micro"
redis_port                 = 6379
redis_num_cache_clusters   = 2
redis_parameter_group_name = "default.redis7"
redis_auth_token           = "replace-with-a-long-random-redis-auth-token"

snapshot_retention_days = 7
snapshot_window         = "18:00-19:00"
maintenance_window      = "sun:19:00-sun:20:00"
